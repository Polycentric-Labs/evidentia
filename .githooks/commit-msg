#!/usr/bin/env bash
# .githooks/commit-msg — phrase-audit gate for commit messages.
#
# Delegates to scripts/check_docs_health.py --check-commit-msg, which
# loads its forbidden-phrase regex set from a gitignored config file
# (private/check-docs-health-patterns.yaml). If the config is absent,
# the gate silently passes — the public source ships no patterns.
#
# Activation (one-time per clone):
#   git config core.hooksPath .githooks
#
# Or run scripts/setup-githooks.sh which sets the config + chmod's the
# hook in one step.
#
# Bypass (rare; use sparingly + with rationale logged elsewhere):
#   EVIDENTIA_ALLOW_PHRASE_BYPASS=1 git commit -m "..."
#
# Legacy bypass var still honored for one cycle for in-flight clones:
#   EVIDENTIA_ALLOW_TIER_VOCAB_IN_COMMIT=1
#
# Both vars do the same thing; new clones should use the new name.

set -euo pipefail

if [ -n "${EVIDENTIA_ALLOW_PHRASE_BYPASS:-}" ] || \
   [ -n "${EVIDENTIA_ALLOW_TIER_VOCAB_IN_COMMIT:-}" ]; then
    echo "commit-msg: bypass active; skipping phrase-audit check." >&2
    exit 0
fi

# Path to the message file is passed as $1 by git.
MESSAGE_FILE="$1"

# Locate the project root (where .git/ lives).
REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT="${REPO_ROOT}/scripts/check_docs_health.py"

if [ ! -f "${SCRIPT}" ]; then
    echo "commit-msg: ${SCRIPT} not found; skipping phrase-audit check." >&2
    exit 0
fi

# Prefer `uv run` if available; fall back to plain python.
if command -v uv >/dev/null 2>&1; then
    uv run python "${SCRIPT}" --check-commit-msg "${MESSAGE_FILE}"
else
    python "${SCRIPT}" --check-commit-msg "${MESSAGE_FILE}"
fi
